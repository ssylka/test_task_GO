# Порт HTTP-сервера приложения.
APP_PORT=8080

# Подключение приложения к базе данных.
DB_HOST=db
DB_PORT=5432
DB_USER=wallet
DB_PASSWORD=wallet
DB_NAME=wallet
# Максимум соединений в пуле к базе (важно для нагрузки).
DB_MAX_CONNS=50

# Переменные для официального образа PostgreSQL — он создаёт базу при первом
# запуске. Должны совпадать с DB_USER / DB_PASSWORD / DB_NAME выше.
POSTGRES_USER=wallet
POSTGRES_PASSWORD=wallet
POSTGRES_DB=wallet
